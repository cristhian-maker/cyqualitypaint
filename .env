# ==========================================
# CY Quality Paint - Environment Variables
# ==========================================

# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ------------------------------------------
# Twilio Configuration
# ------------------------------------------
# Get these from your Twilio Console: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15863821603
TWILIO_WHATSAPP_NUMBER=+15863821603

# ------------------------------------------
# Google APIs Configuration
# ------------------------------------------
# 1. Go to https://console.cloud.google.com
# 2. Create a new project
# 3. Enable Google Calendar API and Gmail API
# 4. Create OAuth 2.0 credentials
# 5. Download credentials.json and extract the values
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://cyqualitypaint.com/api/auth/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_CALENDAR_ID=primary

# ------------------------------------------
# QuickBooks Configuration
# ------------------------------------------
# 1. Go to https://developer.intuit.com
# 2. Create a new app
# 3. Get Client ID and Client Secret
# 4. Set redirect URI in app settings
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret_here
QUICKBOOKS_REDIRECT_URI=https://cyqualitypaint.com/api/quickbooks/callback
QUICKBOOKS_SANDBOX=false
QUICKBOOKS_COMPANY_ID=your_quickbooks_company_id_here

# ------------------------------------------
# OpenAI Configuration (for Chatbot)
# ------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------
# Email Configuration (SendGrid)
# ------------------------------------------
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=info@cyqualitypaint.com
EMAIL_FROM_NAME=CY Quality Paint

# ------------------------------------------
# Database (Optional - for storing leads)
# ------------------------------------------
# You can use Airtable, MongoDB Atlas, or any other database
DATABASE_URL=your_database_url_here

# ------------------------------------------
# Calendly (Optional - for booking)
# ------------------------------------------
CALENDLY_API_KEY=your_calendly_api_key_here
CALENDLY_EVENT_TYPE_URL=https://calendly.com/cyqualitypaint/estimate

# ------------------------------------------
# Slack (Optional - for notifications)
# ------------------------------------------
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ------------------------------------------
# Analytics
# ------------------------------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
FACEBOOK_PIXEL_ID=your_facebook_pixel_id
